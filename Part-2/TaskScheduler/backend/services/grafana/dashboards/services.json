{
  "dashboard": {
    "title": "TaskScheduler Services",
    "tags": ["taskscheduler", "services"],
    "timezone": "UTC",
    "schemaVersion": 38,
    "version": 0,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Status",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "up{job=~'auth-service|task-service|api-gateway'}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "refId": "A",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~'5..'}[5m])",
            "refId": "A",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Response Time (P95)",
        "type": "graph",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 12
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, http_request_duration_seconds_bucket)",
            "refId": "A",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "gridPos": {
          "x": 8,
          "y": 12,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_cache_hits_total[5m]) / (rate(http_cache_hits_total[5m]) + rate(http_cache_misses_total[5m]))",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
